# Настройки Soulseek (через slskd)
# SLSKD_URL=http://localhost:5030
# SLSKD_USER=username
# SLSKD_PASS=password
# SLSKD_DOWNLOADS_PATH=C:/path/to/slskd/downloads

# Настройки Яндекс Музыки (для высокого качества и FLAC)
# YANDEX_TOKEN=your_yandex_oauth_token

# Настройки Сбер Звук (для FLAC и HIGH качества)
# ZVUK_TOKEN=your_zvuk_auth_token

# Настройки Monochrome (необязательно, используются публичные по умолчанию)
# MONOCHROME_HIFI_URL=https://api.monochrome.tf
# MONOCHROME_QOBUZ_PROXY_URL=https://qobuz.kennyy.com.br

# Путь для сохранения скачанных треков
# DOWNLOAD_DIR=./downloads
